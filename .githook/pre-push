#!/bin/bash

echo "Running pre-push checks..."

# 获取当前分支
CURRENT_BRANCH=$(git symbolic-ref --short HEAD)

# 如果是main/master分支，进行额外检查
if [ "$CURRENT_BRANCH" = "main" ] || [ "$CURRENT_BRANCH" = "master" ]; then
    echo "You are pushing to $CURRENT_BRANCH branch. Running additional checks..."
    
    # 检查是否有未解决的TODO注释
    echo "Checking for TODO comments..."
    TODO_COUNT=$(grep -r "TODO" --include="*.rs" --include="*.toml" --include="*.md" . 2>/dev/null | grep -v ".git" | wc -l)
    if [ "$TODO_COUNT" -gt 0 ]; then
        echo "Warning: Found $TODO_COUNT TODO comments. Consider resolving them before pushing to $CURRENT_BRANCH."
        grep -r "TODO" --include="*.rs" --include="*.toml" --include="*.md" . 2>/dev/null | grep -v ".git" || true
        
        # 在非交互式环境中自动继续，避免阻塞
        if [ -t 0 ]; then
            # 交互式终端
            read -p "Continue anyway? (y/n): " -n 1 -r
            echo
            if [[ ! $REPLY =~ ^[Yy]$ ]]; then
                echo "Push cancelled."
                exit 1
            fi
        else
            # 非交互式环境（如git hook），输出警告但继续
            echo "Warning: TODO comments found but continuing in non-interactive mode."
        fi
    fi
    
    # 检查是否有FIXME注释
    echo "Checking for FIXME comments..."
    FIXME_COUNT=$(grep -r "FIXME" --include="*.rs" --include="*.toml" --include="*.md" . 2>/dev/null | grep -v ".git" | wc -l)
    if [ "$FIXME_COUNT" -gt 0 ]; then
        echo "Warning: Found $FIXME_COUNT FIXME comments. Consider resolving them before pushing to $CURRENT_BRANCH."
        grep -r "FIXME" --include="*.rs" --include="*.toml" --include="*.md" . 2>/dev/null | grep -v ".git" || true
        
        # 在非交互式环境中自动继续，避免阻塞
        if [ -t 0 ]; then
            # 交互式终端
            read -p "Continue anyway? (y/n): " -n 1 -r
            echo
            if [[ ! $REPLY =~ ^[Yy]$ ]]; then
                echo "Push cancelled."
                exit 1
            fi
        else
            # 非交互式环境（如git hook），输出警告但继续
            echo "Warning: FIXME comments found but continuing in non-interactive mode."
        fi
    fi
    
    # 检查代码是否可以编译
    echo "Checking if code compiles..."
    cargo check
    if [ $? -ne 0 ]; then
        echo "Code does not compile. Cannot push to $CURRENT_BRANCH."
        exit 1
    fi
    
    # 运行完整的测试套件
    echo "Running full test suite..."
    cargo test --verbose
    if [ $? -ne 0 ]; then
        echo "Tests failed. Cannot push to $CURRENT_BRANCH."
        exit 1
    fi
fi

echo "Pre-push checks passed!"